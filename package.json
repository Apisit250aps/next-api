{
  "name": "@aps/next-api",
  "version": "0.1.1",
  "private": false,
  "license": "MIT",
  "description": "Reusable Hono and MongoDB controller/repository toolkit with shared API types.",
  "type": "module",
  "main": "./packages/core/dist/index.js",
  "types": "./packages/core/dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./packages/core/dist/index.d.ts",
      "default": "./packages/core/dist/index.js"
    },
    "./controller": {
      "types": "./packages/core/dist/controller.d.ts",
      "default": "./packages/core/dist/controller.js"
    },
    "./repository": {
      "types": "./packages/core/dist/repository.d.ts",
      "default": "./packages/core/dist/repository.js"
    },
    "./base-controller": {
      "types": "./packages/core/dist/base-controller.d.ts",
      "default": "./packages/core/dist/base-controller.js"
    },
    "./base-repository": {
      "types": "./packages/core/dist/base-repository.d.ts",
      "default": "./packages/core/dist/base-repository.js"
    },
    "./field": {
      "types": "./packages/core/dist/field.d.ts",
      "default": "./packages/core/dist/field.js"
    },
    "./types": {
      "types": "./packages/types/dist/index.d.ts",
      "default": "./packages/types/dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "packages/core",
    "packages/types",
    "README.md",
    "release"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "build:types": "npm run build -w @aps/next-api-types",
    "build:core": "npm run build -w @aps/next-api-core",
    "build:packages": "npm run build:types && npm run build:core",
    "build:all": "npm run build:packages && npm run build",
    "prepare": "npm run build:packages",
    "start": "node dist/index.js",
    "lint": "eslint",
    "clean:packages": "npm run clean --workspaces --if-present"
  },
  "dependencies": {
    "@aps/next-api-core": "file:packages/core",
    "@aps/next-api-types": "file:packages/types",
    "@hono/node-server": "^1.19.12",
    "hono": "^4.12.10",
    "lodash": "^4.18.1",
    "mongodb": "^7.1.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20",
    "eslint": "^9",
    "typescript": "^5",
    "typescript-eslint": "^8.46.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Apisit250aps/next-api.git"
  },
  "bugs": {
    "url": "https://github.com/Apisit250aps/next-api/issues"
  },
  "homepage": "https://github.com/Apisit250aps/next-api#readme"
}
