{
  "name": "@aps/next-api",
  "version": "0.2.2",
  "private": false,
  "license": "MIT",
  "description": "Reusable Hono and MongoDB controller/repository toolkit with shared API types.",
  "type": "module",
  "main": "./packages/dist/index.js",
  "types": "./packages/dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./packages/dist/index.d.ts",
      "default": "./packages/dist/index.js"
    },
    "./controller": {
      "types": "./packages/dist/controller/index.d.ts",
      "default": "./packages/dist/controller/index.js"
    },
    "./repository": {
      "types": "./packages/dist/repository/index.d.ts",
      "default": "./packages/dist/repository/index.js"
    },
    "./entities": {
      "types": "./packages/dist/entities/index.d.ts",
      "default": "./packages/dist/entities/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "packages",
    "README.md",
    "release"
  ],
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "npm.cmd run build:packages && tsc",
    "build:core": "npm run build --prefix packages",
    "build:packages": "npm run build:core",
    "build:all": "npm run build:packages && npm run build",
    "prepare": "npm run build:packages",
    "start": "node dist/index.js",
    "lint": "eslint",
    "clean:packages": "npm run clean --prefix packages"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "hono": "^4.12.10",
    "lodash": "^4.18.1",
    "mongodb": "^7.1.1",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20",
    "eslint": "^9",
    "typescript": "^5",
    "typescript-eslint": "^8.46.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Apisit250aps/next-api.git"
  },
  "bugs": {
    "url": "https://github.com/Apisit250aps/next-api/issues"
  },
  "homepage": "https://github.com/Apisit250aps/next-api#readme"
}
