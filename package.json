{
  "name": "core",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "build:types": "npm run build -w @aps/core-types",
    "build:core": "npm run build -w @aps/core",
    "build:packages": "npm run build:types && npm run build:core",
    "build:all": "npm run build:packages && npm run build",
    "start": "node dist/index.js",
    "lint": "eslint",
    "clean:packages": "npm run clean --workspaces --if-present"
  },
  "dependencies": {
    "@aps/core": "workspace:*",
    "@aps/core-types": "workspace:*",
    "@hono/node-server": "^1.19.12",
    "hono": "^4.12.10",
    "lodash": "^4.18.1",
    "mongodb": "^7.1.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20",
    "eslint": "^9",
    "typescript": "^5",
    "typescript-eslint": "^8.46.1"
  }
}
