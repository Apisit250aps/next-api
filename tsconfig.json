{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@aps/next-api-core": [
        "./packages/dist/index.d.ts"
      ],
      "@aps/next-api-core/controller": [
        "./packages/dist/controller/index.d.ts"
      ],
      "@aps/next-api-core/repository": [
        "./packages/dist/repository/index.d.ts"
      ],
      "@aps/next-api-core/base-controller": [
        "./packages/dist/controller/base-controller.d.ts"
      ],
      "@aps/next-api-core/base-repository": [
        "./packages/dist/repository/base-repository.d.ts"
      ],
      "@aps/next-api-core/fields": [
        "./packages/dist/fields/index.d.ts"
      ],
      "@aps/next-api-core/field": [
        "./packages/dist/fields/index.d.ts"
      ],
      "@aps/next-api-types": [
        "./packages/src/types/index.d.ts"
      ]
    },
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "exclude": [
    "node_modules"
  ],
  "include": [
    "src/**/*"
  ]
}