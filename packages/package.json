{
  "name": "@aps/next-api-core",
  "version": "0.2.2",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./controller": {
      "types": "./dist/controller/index.d.ts",
      "default": "./dist/controller/index.js"
    },
    "./repository": {
      "types": "./dist/repository/index.d.ts",
      "default": "./dist/repository/index.js"
    },
    "./entities": {
      "types": "./dist/entities/index.d.ts",
      "default": "./dist/entities/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json",
    "clean": "node -e \"const fs=require('node:fs');const path=require('node:path');if(fs.existsSync('dist'))fs.rmSync('dist',{recursive:true,force:true});const walk=(dir)=>{for(const entry of fs.readdirSync(dir,{withFileTypes:true})){const full=path.join(dir,entry.name);if(entry.isDirectory())walk(full);else if(entry.isFile()&&full.endsWith('.js'))fs.rmSync(full,{force:true});}};if(fs.existsSync('src'))walk('src');\""
  },
  "peerDependencies": {
    "hono": "^4.0.0",
    "mongodb": "^7.0.0",
    "uuid": "^14.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "rimraf": "^6.0.1"
  }
}
