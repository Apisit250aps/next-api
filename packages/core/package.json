{
  "name": "@aps/core",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./controller": {
      "types": "./dist/controller.d.ts",
      "default": "./dist/controller.js"
    },
    "./repository": {
      "types": "./dist/repository.d.ts",
      "default": "./dist/repository.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@aps/core-types": "^0.1.0"
  },
  "peerDependencies": {
    "hono": "^4.0.0",
    "mongodb": "^7.0.0",
    "uuid": "^13.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "rimraf": "^6.0.1"
  }
}
